{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["bun-types"],
    "lib": ["ES2022"],
    "resolveJsonModule": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*", "server/**/*"]
}
